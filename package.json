{
  "name": "flowboard",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "turbo": "^2.9.11",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md}": [
      "prettier --write",
      "git add"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  }
}
